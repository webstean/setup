# yaml-language-server: $schema=https://aka.ms/configuration-dsc-schema/0.2
properties:
  configurationVersion: 0.2.0
  assertions:
    - resource: Microsoft.Windows.Developer/OsVersion
      directives:
        description: Verify min OS version requirement
        allowPrerelease: true
      settings:
        MinVersion: '10.0.25000'

  resources:
    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: DesiredStateConfiguration
      directives:
        description: Install DesiredStateConfiguration
        allowPrerelease: false
        securityContext: elevated
      settings:
        id: 9NVTPZWRC6KQ
        source: msstore

    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: Windows.Camera
      directives:
        description: Install Windows.Camera
        allowPrerelease: false
        securityContext: elevated
      settings:
        id: 9WZDNCRFJBBG
        source: msstore

    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: Microsoft.Company.Portal
      directives:
        description: Install Microsoft.Company.Portal
        allowPrerelease: false
      settings:
        id: 9WZDNCRFJ3PZ
        source: msstore

    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: Raw.Image.Extension
      directives:
        description: Install Raw Image Extension
        allowPrerelease: false
      settings:
        id: 9NCTDW2W1BH8
        source: msstore

    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: Microsoft.VisualStudioCode
      directives:
        description: Install Visual Studio Code
        securityContext: elevated
      settings:
        id: Microsoft.VisualStudioCode
        source: winget

    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: Microsoft.Aspire
      directives:
        description: Install Microsoft Aspire CLI
        securityContext: elevated
      settings:
        id: Microsoft.Aspire
        source: winget

    - resource: PSDscResources/Script
      id: variable.developer
      directives:
        description: Set the Developer environment variables in the Machine scope 
        securityContext: elevated
      settings:
        GetScript: return $false
        TestScript: return $false
        SetScript: |
          ## DEVELOPER = YES
          [System.Environment]::SetEnvironmentVariable("DEVELOPER","Yes","Machine")
          ## _NT_SYMBOL_PATH = "srv*C:\Symbols*https://msdl.microsoft.com/download/symbols",
          $Symbols = "$env:SystemDrive\Symbols"
          if (-Not (Test-Path -Path "${Symbols}" -PathType Container -ErrorAction SilentlyContinue)) {
            New-Item -Path "${Symbols}" -Type Container
          } 
          [System.Environment]::SetEnvironmentVariable(
            "_NT_SYMBOL_PATH",
            "srv*${Symbols}*https://msdl.microsoft.com/download/symbols",
            [System.EnvironmentVariableTarget]::Machine
          )

    - resource: PSDscResources/Script
      id: Script.Set.User.Wallpaper
      directives:
        description: Set Developer USER wallpaper
        securityContext: elevated
      settings:
        GetScript: return $false
        TestScript: return $false
        SetScript: |
          $wallpaper = "default-wallpaper.jpg"
          $regPath = "HKCU:\Control Panel\Desktop"
          $regName = "wallpaper"
          $location = "$env:ALLUSERSPROFILE"
          $wallpaperlocation = "${location}\${wallpaper}"
          if (Test-Path "$wallpaperlocation" ) {          
            Set-ItemProperty -Path $regPath -Name $regName -Value $wallpaperlocation
            rundll32.exe user32.dll, UpdatePerUserSystemParameters
            Write-Host "Set USER Wallpaper"
          } else {
            Write-Host "Wallpaper '$wallpaperlocation' was not found!"          
          }

    - resource: PSDscResources/Script
      id: Script.Set.Logon.Wallpaper
      directives:
        description: Set Developer LOGON wallpaper (won't see it on DevBox/Windows 365)
        securityContext: elevated
      dependsOn:
        - Script.Set.User.Wallpaper
      settings:
        GetScript: return $false
        TestScript: return $false
        SetScript: |
          $wallpaper = "default-wallpaper.jpg"
          $regPath = "HKLM:\SOFTWARE\Policies\Microsoft\Windows\System"
          $regName = "wallpaper"
          $location = "$env:ALLUSERSPROFILE"
          $wallpaperlocation = "${location}\${wallpaper}"
          if (Test-Path "$wallpaperlocation" ) {          
            Set-ItemProperty -Path $regPath -Name $regName -Value $wallpaperlocation
            Write-Host "Set LOGON Wallpaper"
          } else {
            Write-Host "Wallpaper '$wallpaperlocation' was not found!"          
          }

