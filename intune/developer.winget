      id: DesiredStateConfiguration
      directives:
        description: Install DesiredStateConfiguration
        allowPrerelease: false
        securityContext: elevated
      settings:
        id: 9NVTPZWRC6KQ
        source: msstore

    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: Windows.Camera
      directives:
        description: Install Windows.Camera
        allowPrerelease: false
        securityContext: elevated
      settings:
        id: 9WZDNCRFJBBG
        source: msstore

    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: Microsoft.Company.Portal
      directives:
        description: Install Microsoft.Company.Portal
        allowPrerelease: false
      settings:
        id: 9WZDNCRFJ3PZ
        source: msstore

    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: Raw.Image.Extension
      directives:
        description: Install Raw Image Extension
        allowPrerelease: false
      settings:
        id: 9NCTDW2W1BH8
        source: msstore

    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: Microsoft.VisualStudioCode
      dependsOn:
        - Git.Git
      directives:
        description: Install Visual Studio Code
        securityContext: elevated
      settings:
        id: Microsoft.VisualStudioCode
        source: winget

    - resource: Microsoft.WinGet.DSC/WinGetPackage
      id: Microsoft.Aspire
      directives:
        description: Install Microsoft Aspire CLI
        securityContext: elevated
      settings:
        id: Microsoft.Aspire
