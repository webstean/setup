    - resource: PSDscResources/Script
      id: RedHat.Podman-Desktop-variable
      dependsOn:
        - RedHat.Podman-Desktop
      directives:
        description: Tell .NET Aspire to use Podman rather than Docker
        securityContext: elevated        
      settings:
        GetScript: return $false
        TestScript: return $false
        SetScript: |
          [System.Environment]::SetEnvironmentVariable("ASPIRE_CONTAINER_RUNTIME","podman","Machine")
          [System.Environment]::SetEnvironmentVariable('WSLENV', 'OneDriveCommercial/p:STRONGPASSWORD:USERDNSDOMAIN:USERDOMAIN:USERNAME:UPN:DOCKER_HOST', 'Machine')

