    # VS Code Icon Extension
    - resource: Microsoft.VSCode.Dsc/VSCodeExtension
      id: vscode-icons-team.vscode-icons
      dependsOn:
        - Microsoft.VisualStudioCode
      directives:
        description: Install VSCode extension-> vscode-icons-team.vscode-icons
        allowPrerelease: false
        securityContext: elevated
      settings:
        Name: vscode-icons-team.vscode-icons

    # VS Code ms-azuretools.vscode-apimanagement Extension
#    - resource: Microsoft.VSCode.Dsc/VSCodeExtension
#      id: ms-azuretools.vscode-apimanagement
