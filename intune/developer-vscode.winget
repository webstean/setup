    # VS Code .NET Development Extension
    - resource: Microsoft.VSCode.Dsc/VSCodeExtension
      id: vscode-ms-dotnettools.csharp
      dependsOn:
        - Microsoft.VisualStudioCode
      directives:
        description: Install VSCode extension-> ms-dotnettools.csharp
        allowPrerelease: false
        securityContext: elevated
      settings:
        Name: ms-dotnettools.csharp

    # VS Code Aspire Extension
    - resource: Microsoft.VSCode.Dsc/VSCodeExtension
      id: microsoft-aspire.aspire-vscode
      dependsOn:
        - Microsoft.VisualStudioCode
        - Microsoft.Aspire
      directives:
        description: Install VSCode extension-> microsoft-aspire.aspire-vscode (needs aspire cli installed)
        allowPrerelease: true
        securityContext: elevated
      settings:
        Name: microsoft-aspire.aspire-vscode

    # VS Code GitHub Pull Request Extension
    - resource: Microsoft.VSCode.Dsc/VSCodeExtension
